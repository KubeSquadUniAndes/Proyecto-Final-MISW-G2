    {
      "name": "Users MS",
      "item": [
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/health"
          }
        },
        {
          "name": "Registrar usuario (traveler)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const timestamp = Date.now();",
                  "pm.environment.set('test_email', `newman.${timestamp}@example.com`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Respuesta contiene campos requeridos', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.expect(body).to.have.property('email');",
                  "  pm.expect(body).to.have.property('user_type');",
                  "  pm.expect(body.user_type).to.eql('traveler');",
                  "});",
                  "",
                  "pm.test('Email coincide con el enviado', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.email).to.eql(pm.environment.get('test_email'));",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.environment.set('user_id', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/users/api/v1/users/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Newman\",\n  \"last_name\": \"Test\",\n  \"email\": \"{{test_email}}\",\n  \"phone\": \"+57 300 000 0000\",\n  \"country\": \"Colombia\",\n  \"city\": \"Bogotá\",\n  \"birth_date\": \"1995-01-01\",\n  \"password\": \"{{test_password}}\",\n  \"user_type\": \"traveler\",\n  \"identification_type\": \"CC\",\n  \"identification_number\": \"1111111111\"\n}"
            }
          }
        },
