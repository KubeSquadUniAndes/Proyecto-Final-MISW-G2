{
  "info": {
    "_postman_id": "reservas-ms-collection",
    "name": "Reservas MS - TravelHub",
    "description": "E2E collection for Reservas microservice. Flow: create → list → get (no QR) → availability → update → [reject separate booking] → approve (QR generated) → get (QR verified) → list hotel → cancel (QR invalidated).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
