{
	"info": {
		"_postman_id": "reservas-ms-collection",
		"name": "Reservas MS - TravelHub",
		"description": "Collection for testing Reservas microservice endpoints with hotel_id and room_id",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Create Booking",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 201\", function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"",
							"pm.test(\"Response has booking_id\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('id');",
							"    pm.environment.set(\"booking_id\", jsonData.id);",
							"});",
							"",
							"pm.test(\"Booking has hotel_id and room_id\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('hotel_id');",
							"    pm.expect(jsonData).to.have.property('room_id');",
							"});",
							"",
							"pm.test(\"Status is pending\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.status).to.eql('pending');",
							"});",
							"",
							"pm.test(\"Has booking_code\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.booking_code).to.match(/^TH-2026-/);",
							"});",
							"",
							"pm.test(\"Pricing calculated correctly\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.total_nights).to.eql(4);",
							"    pm.expect(jsonData.total_price).to.eql('600.00');",
							"    pm.expect(jsonData.taxes).to.eql('114.00');",
							"    pm.expect(jsonData.final_price).to.eql('714.00');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{access_token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"hotel_id\": \"{{hotel_id}}\",\n  \"room_id\": \"{{room_id}}\",\n  \"start_time\": \"2026-05-01T15:00:00Z\",\n  \"end_time\": \"2026-05-05T11:00:00Z\",\n  \"room_type\": \"Deluxe\",\n  \"num_guests\": 2,\n  \"price_per_night\": 150.00,\n  \"traveler_name\": \"Test User\",\n  \"traveler_email\": \"test@example.com\",\n  \"traveler_phone\": \"+573001234567\",\n  \"traveler_document\": \"1234567890\",\n  \"notes\": \"Test booking\",\n  \"special_requests\": \"Late check-in\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/reservas/api/v1/bookings/",
					"host": ["{{base_url}}"],
					"path": ["reservas", "api", "v1", "bookings", ""]
				}
			},
			"response": []
		},
		{
			"name": "2. List User Bookings",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response is an array\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.be.an('array');",
							"});",
							"",
							"pm.test(\"Bookings have hotel_id and room_id\", function () {",
							"    var jsonData = pm.response.json();",
							"    if (jsonData.length > 0) {",
							"        pm.expect(jsonData[0]).to.have.property('hotel_id');",
							"        pm.expect(jsonData[0]).to.have.property('room_id');",
							"    }",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{access_token}}"
					}
				],
				"url": {
					"raw": "{{base_url}}/reservas/api/v1/bookings/",
					"host": ["{{base_url}}"],
					"path": ["reservas", "api", "v1", "bookings", ""]
				}
			},
			"response": []
		},
		{
			"name": "3. Get Booking by ID",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Booking has correct ID\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.id).to.eql(pm.environment.get('booking_id'));",
							"});",
							"",
							"pm.test(\"Has hotel_id and room_id\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('hotel_id');",
							"    pm.expect(jsonData).to.have.property('room_id');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{access_token}}"
					}
				],
				"url": {
					"raw": "{{base_url}}/reservas/api/v1/bookings/{{booking_id}}",
					"host": ["{{base_url}}"],
					"path": ["reservas", "api", "v1", "bookings", "{{booking_id}}"]
				}
			},
			"response": []
		},
		{
			"name": "4. Check Room Availability",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response has room_id\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('room_id');",
							"});",
							"",
							"pm.test(\"Has bookings array\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.bookings).to.be.an('array');",
							"});",
							"",
							"pm.test(\"Has summary with status counts\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.summary).to.have.property('confirmed');",
							"    pm.expect(jsonData.summary).to.have.property('pending');",
							"    pm.expect(jsonData.summary).to.have.property('cancelled');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/reservas/api/v1/bookings/availability?room_id={{room_id}}&start_time=2026-05-01T00:00:00Z&end_time=2026-05-10T00:00:00Z",
					"host": ["{{base_url}}"],
					"path": ["reservas", "api", "v1", "bookings", "availability"],
					"query": [
						{
							"key": "room_id",
							"value": "{{room_id}}"
						},
						{
							"key": "start_time",
							"value": "2026-05-01T00:00:00Z"
						},
						{
							"key": "end_time",
							"value": "2026-05-10T00:00:00Z"
						}
					]
				}
			},
			"response": []
		},
		{
			"name": "5. Update Booking",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Notes updated\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.notes).to.eql('Updated notes');",
							"});",
							"",
							"pm.test(\"Updated timestamp changed\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.updated_at).to.not.eql(jsonData.created_at);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "PATCH",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{access_token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"notes\": \"Updated notes\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/reservas/api/v1/bookings/{{booking_id}}",
					"host": ["{{base_url}}"],
					"path": ["reservas", "api", "v1", "bookings", "{{booking_id}}"]
				}
			},
			"response": []
		},
		{
			"name": "6. Approve Booking (Hotel Admin)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Status changed to confirmed\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.status).to.eql('confirmed');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "PATCH",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{access_token}}"
					}
				],
				"url": {
					"raw": "{{base_url}}/reservas/api/v1/bookings/{{booking_id}}/approve",
					"host": ["{{base_url}}"],
					"path": ["reservas", "api", "v1", "bookings", "{{booking_id}}", "approve"]
				}
			},
			"response": []
		},
		{
			"name": "7. List Hotel Bookings (Hotel Role)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response is an array\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.be.an('array');",
							"});",
							"",
							"pm.test(\"All bookings belong to same hotel\", function () {",
							"    var jsonData = pm.response.json();",
							"    var hotelId = pm.environment.get('hotel_id');",
							"    jsonData.forEach(function(booking) {",
							"        pm.expect(booking.hotel_id).to.eql(hotelId);",
							"    });",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{hotel_access_token}}"
					}
				],
				"url": {
					"raw": "{{base_url}}/reservas/api/v1/bookings/hotel/{{hotel_id}}",
					"host": ["{{base_url}}"],
					"path": ["reservas", "api", "v1", "bookings", "hotel", "{{hotel_id}}"]
				}
			},
			"response": []
		},
		{
			"name": "8. Reject Booking (Hotel Admin)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Status changed to cancelled\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.status).to.eql('cancelled');",
							"});",
							"",
							"pm.test(\"Rejection reason in notes\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.notes).to.include('[REJECTED by admin]');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "PATCH",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{access_token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"rejection_reason\": \"Room not available\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/reservas/api/v1/bookings/{{booking_id}}/reject",
					"host": ["{{base_url}}"],
					"path": ["reservas", "api", "v1", "bookings", "{{booking_id}}", "reject"]
				}
			},
			"response": []
		},
		{
			"name": "9. Cancel Booking",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Status changed to cancelled\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.status).to.eql('cancelled');",
							"});",
							"",
							"pm.test(\"Not cancellable anymore\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.cancellable).to.eql(false);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "DELETE",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{access_token}}"
					}
				],
				"url": {
					"raw": "{{base_url}}/reservas/api/v1/bookings/{{booking_id}}",
					"host": ["{{base_url}}"],
					"path": ["reservas", "api", "v1", "bookings", "{{booking_id}}"]
				}
			},
			"response": []
		}
