    {
      "name": "1. Create Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Response has booking_id\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('id');",
              "    pm.environment.set(\"booking_id\", jsonData.id);",
              "});",
              "",
              "pm.test(\"Booking has hotel_id and room_id\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('hotel_id');",
              "    pm.expect(jsonData).to.have.property('room_id');",
              "});",
              "",
              "pm.test(\"Status is pending\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql('pending');",
              "});",
              "",
              "pm.test(\"Has booking_code\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.booking_code).to.match(/^TH-2026-/);",
              "});",
              "",
              "pm.test(\"Pricing calculated correctly\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.total_nights).to.eql(4);",
              "    pm.expect(jsonData.total_price).to.eql('600.00');",
              "    pm.expect(jsonData.taxes).to.eql('114.00');",
              "    pm.expect(jsonData.final_price).to.eql('714.00');",
              "});",
              "",
              "pm.test(\"QR fields absent on creation (pending)\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.qr_code).to.be.null;",
              "    pm.expect(jsonData.qr_is_valid).to.eql(true);",
              "    pm.expect(jsonData.qr_generated_at).to.be.null;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
