    {
      "name": "8. Approve Booking (Hotel Admin) - QR generated",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Status changed to confirmed\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql('confirmed');",
              "});",
              "",
              "pm.test(\"QR code is generated on approval\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.qr_code).to.not.be.null;",
              "    pm.expect(jsonData.qr_code).to.be.a('string');",
              "    pm.expect(jsonData.qr_code.length).to.be.greaterThan(100);",
              "    pm.environment.set(\"qr_code\", jsonData.qr_code);",
              "});",
              "",
              "pm.test(\"QR is marked valid after approval\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.qr_is_valid).to.eql(true);",
              "});",
              "",
              "pm.test(\"QR has generation timestamp\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.qr_generated_at).to.not.be.null;",
              "    var generatedAt = new Date(jsonData.qr_generated_at);",
              "    pm.expect(generatedAt.getTime()).to.be.greaterThan(0);",
              "});",
              "",
              "pm.test(\"QR code is valid base64\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.qr_code).to.match(/^[A-Za-z0-9+\\/]+=*$/);",
              "});",
              "",
              "pm.test(\"QR code encodes booking_code in payload\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.booking_code).to.match(/^TH-2026-/);",
              "    pm.expect(jsonData.qr_code).to.be.a('string').and.have.length.greaterThan(100);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
